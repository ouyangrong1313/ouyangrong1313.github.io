/**
 * 童年跳房子大挑战 - app.wxss
 * 全局样式
 */

/* 复古手绘风格主题色 */
page {
  --primary-color: #FF6B6B;      /* 珊瑚红 */
  --secondary-color: #4ECDC4;     /* 薄荷绿 */
  --accent-color: #FFE66D;         /* 柠檬黄 */
  --bg-color: #FFF8DC;             /* 玉米丝色/米白 */
  --text-color: #5D4E37;           /* 棕色文字 */
  --chalk-white: #FFFEF2;         /* 粉笔白 */
  --chalk-pink: #FFB6C1;          /* 粉笔粉 */
  --chalk-blue: #87CEEB;          /* 粉笔蓝 */
  --ground-brown: #D2691E;        /* 地面棕色 */
  --sky-blue: #87CEEB;            /* 天空蓝 */

  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', sans-serif;
  font-size: 28rpx;
  color: var(--text-color);
  background-color: var(--bg-color);
}

/* 通用按钮样式 */
.btn-primary {
  background: linear-gradient(135deg, var(--primary-color) 0%, #FF8E8E 100%);
  color: white;
  border: none;
  border-radius: 50rpx;
  padding: 24rpx 60rpx;
  font-size: 32rpx;
  font-weight: bold;
  box-shadow: 0 8rpx 20rpx rgba(255, 107, 107, 0.4);
  position: relative;
  overflow: hidden;
}

.btn-primary::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.3), transparent);
  transition: left 0.5s;
}

.btn-primary:active::before {
  left: 100%;
}

.btn-secondary {
  background: linear-gradient(135deg, var(--secondary-color) 0%, #7EDDD6 100%);
  color: white;
  border: none;
  border-radius: 50rpx;
  padding: 24rpx 60rpx;
  font-size: 32rpx;
  font-weight: bold;
  box-shadow: 0 8rpx 20rpx rgba(78, 205, 196, 0.4);
}

/* 卡片容器 */
.card {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 30rpx;
  padding: 40rpx;
  box-shadow: 0 10rpx 40rpx rgba(0, 0, 0, 0.1);
  border: 4rpx dashed var(--primary-color);
}

/* 粉笔线条效果 */
.chalk-line {
  position: relative;
}

.chalk-line::after {
  content: '';
  position: absolute;
  bottom: -10rpx;
  left: 0;
  width: 100%;
  height: 6rpx;
  background: repeating-linear-gradient(
    90deg,
    var(--chalk-white) 0rpx,
    var(--chalk-white) 8rpx,
    transparent 8rpx,
    transparent 16rpx
  );
}

/* 复古地面样式 */
.retro-ground {
  background: linear-gradient(180deg,
    var(--ground-brown) 0%,
    #8B4513 50%,
    #654321 100%
  );
  border-top: 8rpx solid #3D2314;
}

/* 主标题样式 */
.main-title {
  font-size: 56rpx;
  font-weight: bold;
  color: var(--primary-color);
  text-shadow: 4rpx 4rpx 0rpx rgba(0,0,0,0.1);
  letter-spacing: 4rpx;
}

/* 副标题样式 */
.sub-title {
  font-size: 28rpx;
  color: var(--text-color);
  opacity: 0.8;
}

/* 分数显示样式 */
.score-display {
  font-size: 80rpx;
  font-weight: bold;
  color: var(--accent-color);
  text-shadow: 4rpx 4rpx 0rpx var(--primary-color);
}

/* 动画效果 */
@keyframes bounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-20rpx); }
}

@keyframes shake {
  0%, 100% { transform: translateX(0); }
  25% { transform: translateX(-10rpx); }
  75% { transform: translateX(10rpx); }
}

@keyframes pulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.1); }
}

@keyframes float {
  0%, 100% { transform: translateY(0) rotate(0deg); }
  50% { transform: translateY(-15rpx) rotate(5deg); }
}

.animate-bounce {
  animation: bounce 1s ease-in-out infinite;
}

.animate-shake {
  animation: shake 0.5s ease-in-out;
}

.animate-pulse {
  animation: pulse 1s ease-in-out infinite;
}

.animate-float {
  animation: float 2s ease-in-out infinite;
}

/* 弹性布局 */
.flex-center {
  display: flex;
  justify-content: center;
  align-items: center;
}

.flex-between {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.flex-column {
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* 间距 */
.mt-20 { margin-top: 20rpx; }
.mt-40 { margin-top: 40rpx; }
.mt-60 { margin-top: 60rpx; }
.mb-20 { margin-bottom: 20rpx; }
.mb-40 { margin-bottom: 40rpx; }
.mb-60 { margin-bottom: 60rpx; }
